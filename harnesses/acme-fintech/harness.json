{
  "name": "acme-fintech",
  "version": "0.1.0",
  "branding": { "displayName": "Acme Engineer", "accent": "#0E7C61" },
  "promptLibrary": "prompts",
  "systemPrompt": "lib:platform-eng-base",
  "appendSystemPrompt": "system-prompt-acme.md",
  "skills": [{ "path": "skills/incident-triage", "mandatory": true }],
  "providers": {
    "default": { "provider": "anthropic", "model": "claude-sonnet-5", "credentialProfile": "platform-eng" }
  },
  "mcp": {
    "servers": {
      "internal_docs": {
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/srv/acme/docs"],
        "mandatory": false,
        "tools": ["read_file", "list_directory", "search_files"]
      },
      "analytics_readonly": {
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://analytics_ro@analytics-replica.internal:5432/acme_analytics"],
        "secrets": { "PGPASSWORD": "acme-analytics-ro" },
        "mandatory": false,
        "tools": ["query"]
      }
    }
  }
}
